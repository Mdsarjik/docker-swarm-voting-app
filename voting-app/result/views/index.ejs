<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>📊 Live Results — Docker Swarm Voting App</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="refresh" content="3">
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Courier New', monospace;
        background: #0D1117;
        color: #c9d1d9;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .terminal-bar {
        position: fixed;
        top: 0; left: 0; right: 0;
        background: #161b22;
        border-bottom: 1px solid #21262d;
        padding: 10px 24px;
        font-size: 13px;
        color: #3fb950;
        display: flex;
        justify-content: space-between;
      }

      .container {
        text-align: center;
        padding: 2rem;
        max-width: 700px;
        width: 100%;
      }

      .header h1 {
        font-size: 13px;
        color: #3fb950;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .header h2 {
        font-size: 30px;
        font-weight: 700;
        color: #f0f6fc;
        margin-bottom: 32px;
      }

      .results {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 40px;
      }

      .result-row {
        background: #161b22;
        border: 1px solid #21262d;
        border-radius: 8px;
        padding: 20px 24px;
      }

      .result-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
      }

      .result-name {
        font-size: 18px;
        font-weight: 700;
        color: #f0f6fc;
      }

      .result-count {
        font-size: 28px;
        font-weight: 700;
        color: #3fb950;
      }

      .bar-bg {
        height: 10px;
        background: #21262d;
        border-radius: 5px;
        overflow: hidden;
      }

      .bar-fill {
        height: 100%;
        background: linear-gradient(to right, #238636, #3fb950);
        border-radius: 5px;
        transition: width 0.5s ease;
      }

      .bar-fill.b {
        background: linear-gradient(to right, #1f6feb, #58a6ff);
      }

      .result-pct {
        font-size: 12px;
        color: #484f58;
        margin-top: 8px;
        text-align: right;
        letter-spacing: 0.08em;
      }

      .total {
        font-size: 12px;
        color: #484f58;
        letter-spacing: 0.1em;
        margin-bottom: 12px;
      }

      .refresh-note {
        font-size: 11px;
        color: #30363d;
        letter-spacing: 0.08em;
        margin-top: 24px;
      }

      .vote-link {
        margin-top: 20px;
        font-size: 12px;
        color: #484f58;
      }

      .vote-link a {
        color: #58a6ff;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="terminal-bar">
      <span>sharjik@swarm:~$ watch -n3 docker service ps voting-app_worker</span>
      <span style="color:#484f58; font-size:11px;">auto-refresh: 3s</span>
    </div>

    <div class="container">
      <div class="header">
        <h1>$ live results</h1>
        <h2>Current Vote Count</h2>
      </div>

      <div class="total">TOTAL VOTES: <%= total %></div>

      <div class="results">
        <div class="result-row">
          <div class="result-top">
            <div class="result-name">🐱 <%= option_a %></div>
            <div class="result-count"><%= count_a %></div>
          </div>
          <div class="bar-bg">
            <div class="bar-fill" style="width: <%= percent_a %>%"></div>
          </div>
          <div class="result-pct"><%= percent_a %>%</div>
        </div>

        <div class="result-row">
          <div class="result-top">
            <div class="result-name">🐶 <%= option_b %></div>
            <div class="result-count"><%= count_b %></div>
          </div>
          <div class="bar-bg">
            <div class="bar-fill b" style="width: <%= percent_b %>%"></div>
          </div>
          <div class="result-pct"><%= percent_b %>%</div>
        </div>
      </div>

      <div class="refresh-note">↻ page auto-refreshes every 3 seconds</div>

      <div class="vote-link">
        Cast your vote → <a href="http://localhost:5000" target="_blank">localhost:5000</a>
      </div>
    </div>
  </body>
</html>
